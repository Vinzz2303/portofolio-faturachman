DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=fatur_life_os

# Gemini API (optional; if not set, service will use local fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Ting AI v1.9 LLM fallback chain: Gemini -> Groq -> local template
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=
GROQ_MODEL=
GROQ_REQUEST_TIMEOUT_MS=7000
TING_AI_PROVIDER_TIMEOUT_MS=7000
TING_AI_PROVIDER_RETRIES=1

TWELVEDATA_API_KEY=
MARKETAUX_API_TOKEN=

PORT=3001
PORTFOLIO_REFRESH_ENABLED=true
PORTFOLIO_REFRESH_INTERVAL_MS=1800000
PORTFOLIO_REFRESH_RUN_ON_STARTUP=true
